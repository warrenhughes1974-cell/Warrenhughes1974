{
  "version": "1.0",
  "description": "Phase 11 prototype QUIKCLMS/QUIKCLMP DBF generation rules (QA/UAT only, not production).",
  "prototype_mode": true,
  "production_dbf_flag": "N",
  "claimnum_strategy": {
    "prefix": "CLM",
    "width": 7,
    "format": "{prefix}{sequence:0{width}d}",
    "sort_key": "reconstructed_claim_id",
    "collision_policy": "sequence_increment",
    "notes": "Deterministic prototype numbering; not production claim numbers"
  },
  "gating_rules": {
    "require_derivation_status": "RULEBOOK_READY",
    "require_validation_result": "PASS",
    "minimum_confidence": "MODERATE_CONFIDENCE",
    "accepted_confidence_levels": ["HIGH_CONFIDENCE", "MODERATE_CONFIDENCE"]
  },
  "reconciliation_rules": {
    "payment_amount_tolerance": 0.01,
    "net_amount_tolerance": 0.01,
    "flag_orphan_payments": true,
    "flag_missing_claim_header": true,
    "flag_duplicate_mseq": true,
    "flag_payment_count_mismatch": true,
    "preserve_residuals": true
  },
  "quikclms_layout": [
    {"field": "MPOLICY", "type": "CHARACTER", "length": 10, "decimals": 0},
    {"field": "MPHASE", "type": "NUMERIC", "length": 2, "decimals": 0},
    {"field": "CLAIMNUM", "type": "CHARACTER", "length": 20, "decimals": 0},
    {"field": "CLAIMSTAT", "type": "NUMERIC", "length": 2, "decimals": 0},
    {"field": "DTOFDEATH", "type": "DATE", "length": 8, "decimals": 0},
    {"field": "RPTDATE", "type": "DATE", "length": 8, "decimals": 0},
    {"field": "PDDATE", "type": "DATE", "length": 8, "decimals": 0},
    {"field": "MPAID", "type": "NUMERIC", "length": 10, "decimals": 2},
    {"field": "MFACE", "type": "NUMERIC", "length": 10, "decimals": 2},
    {"field": "DIVIDENDS", "type": "NUMERIC", "length": 10, "decimals": 2},
    {"field": "LOAN", "type": "NUMERIC", "length": 10, "decimals": 2},
    {"field": "NETDB", "type": "NUMERIC", "length": 10, "decimals": 2},
    {"field": "PREMIUM", "type": "NUMERIC", "length": 10, "decimals": 2},
    {"field": "SUSPENSE", "type": "NUMERIC", "length": 10, "decimals": 2},
    {"field": "ADJUST", "type": "NUMERIC", "length": 10, "decimals": 2},
    {"field": "CAUSE", "type": "CHARACTER", "length": 3, "decimals": 0},
    {"field": "MEMOTEXT", "type": "MEMO", "length": 10, "decimals": 0},
    {"field": "ORIGSTTUS", "type": "CHARACTER", "length": 2, "decimals": 0},
    {"field": "ACCPTDATE", "type": "DATE", "length": 8, "decimals": 0},
    {"field": "MCONTEST", "type": "LOGICAL", "length": 1, "decimals": 0},
    {"field": "MINTST", "type": "CHARACTER", "length": 2, "decimals": 0},
    {"field": "MINTDAYS", "type": "NUMERIC", "length": 5, "decimals": 0},
    {"field": "MINTRATE", "type": "NUMERIC", "length": 8, "decimals": 2},
    {"field": "MINTAMT", "type": "NUMERIC", "length": 10, "decimals": 2},
    {"field": "MSURRCHG", "type": "LOGICAL", "length": 1, "decimals": 0},
    {"field": "MSEQ", "type": "NUMERIC", "length": 3, "decimals": 0},
    {"field": "MHOLDINT", "type": "NUMERIC", "length": 12, "decimals": 2},
    {"field": "MFEDTAX", "type": "NUMERIC", "length": 12, "decimals": 2},
    {"field": "MSTTAX", "type": "NUMERIC", "length": 12, "decimals": 2},
    {"field": "MCLMPNDLTR", "type": "NUMERIC", "length": 3, "decimals": 0},
    {"field": "MFACPMT", "type": "LOGICAL", "length": 1, "decimals": 0},
    {"field": "MPHPAIDTO", "type": "DATE", "length": 8, "decimals": 0}
  ],
  "quikclmp_layout": [
    {"field": "MPOLICY", "type": "CHARACTER", "length": 10, "decimals": 0},
    {"field": "MPHASE", "type": "NUMERIC", "length": 2, "decimals": 0},
    {"field": "MCHECKNO", "type": "NUMERIC", "length": 7, "decimals": 0},
    {"field": "MAMOUNT", "type": "NUMERIC", "length": 12, "decimals": 2},
    {"field": "MPAYNAME", "type": "CHARACTER", "length": 50, "decimals": 0},
    {"field": "MPAYADDR1", "type": "CHARACTER", "length": 25, "decimals": 0},
    {"field": "MPAYADDR2", "type": "CHARACTER", "length": 25, "decimals": 0},
    {"field": "MPAYCITY", "type": "CHARACTER", "length": 50, "decimals": 0},
    {"field": "MPAYST", "type": "CHARACTER", "length": 2, "decimals": 0},
    {"field": "MPAYZIP", "type": "CHARACTER", "length": 5, "decimals": 0},
    {"field": "MPAYZIP2", "type": "CHARACTER", "length": 4, "decimals": 0},
    {"field": "MTIN", "type": "CHARACTER", "length": 9, "decimals": 0},
    {"field": "MBANKNO", "type": "CHARACTER", "length": 30, "decimals": 0},
    {"field": "MHDPMT", "type": "CHARACTER", "length": 1, "decimals": 0},
    {"field": "MHDCODE", "type": "CHARACTER", "length": 4, "decimals": 0},
    {"field": "MCHKDATE", "type": "DATE", "length": 8, "decimals": 0},
    {"field": "MPMTDATE", "type": "DATE", "length": 8, "decimals": 0},
    {"field": "MSEQ", "type": "NUMERIC", "length": 3, "decimals": 0},
    {"field": "MHOLDINT", "type": "NUMERIC", "length": 12, "decimals": 2},
    {"field": "MFEDTAX", "type": "NUMERIC", "length": 12, "decimals": 2},
    {"field": "MSTTAX", "type": "NUMERIC", "length": 12, "decimals": 2},
    {"field": "MGROSS", "type": "NUMERIC", "length": 12, "decimals": 2},
    {"field": "MDOB", "type": "DATE", "length": 8, "decimals": 0},
    {"field": "MGENDER", "type": "CHARACTER", "length": 1, "decimals": 0},
    {"field": "MCOUNTRY", "type": "CHARACTER", "length": 1, "decimals": 0}
  ],
  "quikclms_field_mapping": {
    "MPOLICY": {"source": "mpolicy", "default": ""},
    "MPHASE": {"source": "mphase", "default": "1"},
    "CLAIMNUM": {"source": "prototype_claimnum", "default": ""},
    "CLAIMSTAT": {"source": "claimstat", "default": "1"},
    "DTOFDEATH": {"source": "mlossdate", "default": null},
    "RPTDATE": {"source": "mnoticedate", "default": null},
    "PDDATE": {"source": "pddate", "default": null},
    "MPAID": {"source": "mpaid", "default": "0"},
    "MFACE": {"source": "mgrossamt", "default": "0"},
    "DIVIDENDS": {"source": "constant", "default": "0"},
    "LOAN": {"source": "mloan", "default": "0"},
    "NETDB": {"source": "netdb", "fallback": "mnetamt", "default": "0"},
    "PREMIUM": {"source": "constant", "default": "0"},
    "SUSPENSE": {"source": "constant", "default": "0"},
    "ADJUST": {"source": "constant", "default": "0"},
    "CAUSE": {"source": "constant", "default": ""},
    "MEMOTEXT": {"source": "mlineage", "default": ""},
    "ORIGSTTUS": {"source": "claimstat", "default": ""},
    "ACCPTDATE": {"source": "msettledate", "default": null},
    "MCONTEST": {"source": "constant", "default": false},
    "MINTST": {"source": "constant", "default": ""},
    "MINTDAYS": {"source": "constant", "default": "0"},
    "MINTRATE": {"source": "constant", "default": "0"},
    "MINTAMT": {"source": "mintamt", "default": "0"},
    "MSURRCHG": {"source": "constant", "default": false},
    "MSEQ": {"source": "constant", "default": "1"},
    "MHOLDINT": {"source": "constant", "default": "0"},
    "MFEDTAX": {"source": "mfedtax", "default": "0"},
    "MSTTAX": {"source": "constant", "default": "0"},
    "MCLMPNDLTR": {"source": "constant", "default": "0"},
    "MFACPMT": {"source": "constant", "default": false},
    "MPHPAIDTO": {"source": "pddate", "default": null}
  },
  "quikclmp_field_mapping": {
    "MPOLICY": {"source": "mpolicy", "default": ""},
    "MPHASE": {"source": "mphase", "default": "1"},
    "MCHECKNO": {"source": "constant", "default": "0"},
    "MAMOUNT": {"source": "mamount", "default": "0"},
    "MPAYNAME": {"source": "mpayname", "default": ""},
    "MPAYADDR1": {"source": "mpayaddr1", "default": ""},
    "MPAYADDR2": {"source": "constant", "default": ""},
    "MPAYCITY": {"source": "mpaycity", "default": ""},
    "MPAYST": {"source": "mpayst", "default": ""},
    "MPAYZIP": {"source": "mpayzip", "default": ""},
    "MPAYZIP2": {"source": "constant", "default": ""},
    "MTIN": {"source": "mtin", "default": ""},
    "MBANKNO": {"source": "constant", "default": ""},
    "MHDPMT": {"source": "derived_mhdpmt", "default": "C"},
    "MHDCODE": {"source": "constant", "default": ""},
    "MCHKDATE": {"source": "mchkdate", "default": null},
    "MPMTDATE": {"source": "mpmtdate", "default": null},
    "MSEQ": {"source": "mseq", "default": "1"},
    "MHOLDINT": {"source": "constant", "default": "0"},
    "MFEDTAX": {"source": "mfedtax", "default": "0"},
    "MSTTAX": {"source": "constant", "default": "0"},
    "MGROSS": {"source": "mamount", "default": "0"},
    "MDOB": {"source": "constant", "default": null},
    "MGENDER": {"source": "constant", "default": ""},
    "MCOUNTRY": {"source": "constant", "default": ""}
  },
  "payment_type_mhdpmt_mapping": {
    "DEATH": "C",
    "CLAIM": "C",
    "DISBURSEMENT": "C",
    "DEATH_CLAIM_PAYOUT": "C",
    "CLAIM_PAYMENT": "C",
    "CASH_DISBURSEMENT": "C",
    "default": "C"
  },
  "required_quikclms_fields": ["MPOLICY", "CLAIMNUM"],
  "required_quikclmp_fields": ["MPOLICY", "MAMOUNT", "MSEQ"]
}
