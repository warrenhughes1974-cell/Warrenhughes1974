    "IMMEDIATE_CHAIN",
    "DELAYED_CHAIN",
    "FUNDED_NO_DISBURSEMENT",
    "PAYOUT_ONLY",
    "MULTI_PAYOUT_CHAIN",
    "ORPHAN_CHAIN",
    "PARTIAL_CHAIN"
