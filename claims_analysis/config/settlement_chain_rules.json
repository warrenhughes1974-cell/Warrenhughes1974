    "HIGH_CONFIDENCE": {
      "requires_same_day_funding_payout": true,
      "requires_semantic_family_match": true,
      "requires_amount_within_tolerance": true,
      "min_payout_linkage_quality": "DIRECT"
    },
    "MODERATE_CONFIDENCE": {
      "max_lag_days": 14,
      "requires_funding_payout_pair": true,
      "allows_partial_amount_alignment": true
    },
    "INFERRED": {
      "allows_cross_claim_linkage": true,
      "allows_offset_only_chain": true
    },
    "LOW_CONFIDENCE": {
      "orphan_or_unlinked": true
    }
  },
  "families": {
