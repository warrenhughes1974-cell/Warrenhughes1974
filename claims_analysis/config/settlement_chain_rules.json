{
  "version": "1.0",
  "description": "Phase 7A settlement chain intelligence rules (read-only validation).",
  "immediate_settlement_days": 0,
  "payout_lag_window_days": 14,
  "settlement_timing_tolerance_days": 3,
  "cross_claim_policy_window_days": 30,
  "delayed_linkage_enabled": true,
  "cross_claim_linkage_enabled": true,
  "orphan_funding_min_amount": 0.01,
  "amount_alignment_tolerance": 100.0,
  "amount_alignment_ratio_tolerance": 0.15,
  "multi_payout_min_count": 2,
  "exclude_lifecycle_event_types": ["CLAIM_SETTLEMENT"],
