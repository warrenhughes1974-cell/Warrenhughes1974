      "expected_chain_pattern": "0530|0630 -> 0094",
      "notes": "Clearing 0038 supports lifecycle linkage only; payout expected same settlement group."
    },
    "SURRENDER_CLAIM": {
      "label": "Surrender Claim",
      "funding_codes": ["0560", "0561"],
      "interest_codes": [],
